{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "philosophy_montage_doctrine_data",
  "type": "object",
  "required": ["meta", "opener", "scenes"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["video_id", "topic", "duration_sec", "style_variant", "tone"],
      "properties": {
        "video_id": {"type": "string"},
        "topic": {"type": "string"},
        "duration_sec": {"type": "number", "minimum": 20},
        "style_variant": {"type": "string"},
        "tone": {"type": "string"},
        "voiceover_enabled": {"type": "boolean"}
      }
    },
    "opener": {
      "type": "object",
      "required": ["intro_title", "concept_terms", "concept_images"],
      "properties": {
        "intro_title": {"type": "string"},
        "concept_terms": {
          "type": "array",
          "minItems": 8,
          "maxItems": 12,
          "items": {"type": "string"}
        },
        "concept_images": {
          "type": "array",
          "minItems": 8,
          "maxItems": 12,
          "items": {"type": "string"}
        },
        "switch_every_frames": {"type": "integer", "minimum": 4}
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["scene_id", "scene_type", "duration_frames", "image", "subtitle_lines", "palette", "intent"],
        "properties": {
          "scene_id": {"type": "string"},
          "scene_type": {
            "type": "string",
            "enum": [
              "titleStack",
              "conceptBoard",
              "ruminationExample",
              "controlSplit",
              "decisionPrompt",
              "axiomWall",
              "cityOutro"
            ]
          },
          "duration_frames": {"type": "integer", "minimum": 60},
          "image": {"type": "string"},
          "subtitle_lines": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {"type": "string"}
          },
          "palette": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {"type": "string"}
          },
          "intent": {"type": "string"}
        }
      }
    },
    "audio": {
      "$ref": "template_data_audio_schema.json#/properties/audio_alignment"
    }
  }
}
