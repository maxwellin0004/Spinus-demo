{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "philosophy_montage_doctrine_audio",
  "type": "object",
  "required": ["voiceover_units", "audio_alignment"],
  "properties": {
    "voiceover_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["voice_id", "visual_section_id", "text"],
        "properties": {
          "voice_id": {"type": "string"},
          "visual_section_id": {"type": "string"},
          "text": {"type": "string"},
          "emphasis_words": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "audio_alignment": {
      "type": "object",
      "required": ["tts_provider", "voiceover_audio_path", "subtitle_timeline_path", "alignment_status"],
      "properties": {
        "tts_provider": {"type": "string", "default": "elevenlabs"},
        "voiceover_audio_path": {"type": "string"},
        "subtitle_timeline_path": {"type": "string"},
        "alignment_status": {
          "type": "string",
          "enum": ["not_generated", "estimated", "aligned", "estimated_after_audio_duration_fit"]
        }
      }
    }
  }
}
