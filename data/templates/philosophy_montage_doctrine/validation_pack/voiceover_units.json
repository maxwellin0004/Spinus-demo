  },
  {
    "voice_id": "sb_v03",
    "section": "problem",
    "text": "一句评价、一条消息、一次冷脸，本来只是事件。你一旦反复回放，它就会从事件变成情绪占领。",
    "target_duration_sec": 7.4,
    "intended_pause_after_sec": 0.25,
    "emphasis_words": ["事件", "反复回放", "情绪占领"],
