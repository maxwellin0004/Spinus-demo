      "textZh": "\u8fd9\u53e5\u8bdd\u4f1a\u523a\u75db\u6240\u6709\n\u4e0d\n\u7518\u5fc3\u5374\u4e00\u76f4\u66ff\u522b\u4eba\u6d3b\u7684\u4eba",
      "textEn": "This line hits everyone\nwho keeps living for other eyes.",
