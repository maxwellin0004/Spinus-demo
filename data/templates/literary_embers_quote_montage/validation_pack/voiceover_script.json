[
  {"time_range": "0.0-4.6", "voice_id": "le_v01", "section": "hook", "voiceover_text": "这句话会刺痛所有不甘心却一直替别人活的人。", "target_duration_sec": 4.6, "intended_pause_after_sec": 0.2, "visual_section_id": "le_s01", "tone": "sharp and low", "pace": "steady", "pauses": "替别人活前轻顿", "emphasis_words": ["替别人活"], "timing_status": "estimated", "notes": "第一句直接命中"},
  {"time_range": "4.6-7.2", "voice_id": "le_v02", "section": "bridge", "voiceover_text": "今天分享《月亮与六便士》。", "target_duration_sec": 2.6, "intended_pause_after_sec": 0.2, "visual_section_id": "le_s02", "tone": "calm", "pace": "slow", "pauses": "书名后轻停", "emphasis_words": ["《月亮与六便士》"], "timing_status": "estimated", "notes": "切入目标书"},
  {"time_range": "7.2-12.3", "voice_id": "le_v03", "section": "body", "voiceover_text": "很多人不是没有天赋，只是从来没替自己活过。", "target_duration_sec": 5.1, "intended_pause_after_sec": 0.28, "visual_section_id": "le_s03", "tone": "measured", "pace": "medium-slow", "pauses": "逗号处", "emphasis_words": ["替自己活过"], "timing_status": "estimated", "notes": "首段判断句"},
  {"time_range": "12.3-17.6", "voice_id": "le_v04", "section": "body", "voiceover_text": "你抱怨生活沉闷，却把每次选择都交给体面和目光。", "target_duration_sec": 5.3, "intended_pause_after_sec": 0.28, "visual_section_id": "le_s04", "tone": "cold", "pace": "medium", "pauses": "沉闷后轻顿", "emphasis_words": ["体面", "目光"], "timing_status": "estimated", "notes": "生活感段落"},
  {"time_range": "17.6-22.2", "voice_id": "le_v05", "section": "body", "voiceover_text": "于是工作是为了交代，努力是为了比较。", "target_duration_sec": 4.6, "intended_pause_after_sec": 0.25, "visual_section_id": "le_s05", "tone": "flat", "pace": "medium-slow", "pauses": "逗号处", "emphasis_words": ["交代", "比较"], "timing_status": "estimated", "notes": "对照句"},
  {"time_range": "22.2-28.0", "voice_id": "le_v06", "section": "body", "voiceover_text": "真正困住人的不是起点，而是听见内心后又把它按回去。", "target_duration_sec": 5.8, "intended_pause_after_sec": 0.28, "visual_section_id": "le_s06", "tone": "heavier", "pace": "medium-slow", "pauses": "不是起点后轻顿", "emphasis_words": ["按回去"], "timing_status": "estimated", "notes": "核心句"},
  {"time_range": "28.0-34.0", "voice_id": "le_v07", "section": "body", "voiceover_text": "不是每个人都要离开现实，但每个人都该有一次为自己负责的决定。", "target_duration_sec": 6.0, "intended_pause_after_sec": 0.32, "visual_section_id": "le_s07", "tone": "firmer", "pace": "measured", "pauses": "但前停顿", "emphasis_words": ["为自己负责"], "timing_status": "estimated", "notes": "结论句"},
  {"time_range": "34.0-39.2", "voice_id": "le_v08", "section": "outro", "voiceover_text": "如果你总怕失去掌声，最后失去的往往就是自己。", "target_duration_sec": 5.2, "intended_pause_after_sec": 0.25, "visual_section_id": "le_s08", "tone": "quiet finish", "pace": "slow", "pauses": "掌声后轻顿", "emphasis_words": ["自己"], "timing_status": "estimated", "notes": "留下余韵"}
]
