  "scenes": [
    {"scene_id": "le_s03", "scene_type": "deskPanel", "duration_frames": 124, "accent_text": "你抄了太多答案", "subtitle_zh": "你读了很多道理，却总在原地打转", "subtitle_en": "You learned many truths, yet kept circling in place.", "scene_image": "/images/literary-embers/panel-siddhartha-desk.png", "illustration_note": "纸页与停笔动作"},
