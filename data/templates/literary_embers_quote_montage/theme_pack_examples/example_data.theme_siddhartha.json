    {"scene_id": "le_s05", "scene_type": "windowPanel", "duration_frames": 128, "accent_text": "安静地听一次自己", "subtitle_zh": "真正的答案，常常出现在你停止比较之后", "subtitle_en": "Your real answer often appears after comparison stops.", "scene_image": "/images/literary-embers/panel-siddhartha-window.png", "illustration_note": "窗边停顿"},
