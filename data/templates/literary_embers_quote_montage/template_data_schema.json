{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "literary_embers_quote_montage_data",
  "type": "object",
  "required": ["meta", "hook", "cover_bridge", "scenes"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["video_id", "book_title", "author_line", "topic_statement", "duration_sec", "style_variant"],
      "properties": {
        "video_id": {"type": "string"},
        "book_title": {"type": "string"},
        "author_line": {"type": "string"},
        "topic_statement": {"type": "string"},
        "duration_sec": {"type": "number", "minimum": 20},
        "style_variant": {"type": "string"},
        "voiceover_enabled": {"type": "boolean"}
      }
    },
    "hook": {
      "type": "object",
      "required": ["scene_type", "symbolic_metaphor", "hook_line_zh", "hook_line_en", "hook_image"],
      "properties": {
        "scene_type": {"type": "string", "enum": ["burnHook"]},
        "symbolic_metaphor": {"type": "string"},
        "hook_line_zh": {"type": "string"},
        "hook_line_en": {"type": "string"},
        "hook_image": {"type": "string"}
      }
    },
    "cover_bridge": {
      "type": "object",
      "required": ["scene_type", "flash_books"],
      "properties": {
        "scene_type": {"type": "string", "enum": ["bookCascade"]},
        "flash_books": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "items": {
            "type": "object",
            "required": ["title", "author", "palette", "cover_image"],
            "properties": {
              "title": {"type": "string"},
              "author": {"type": "string"},
              "palette": {"type": "array", "items": {"type": "string"}, "minItems": 3, "maxItems": 3},
              "cover_image": {"type": "string"},
              "source": {"type": "string"}
            }
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 6,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["scene_id", "scene_type", "duration_frames", "accent_text", "subtitle_zh", "subtitle_en", "scene_image"],
        "properties": {
          "scene_id": {"type": "string"},
          "scene_type": {"type": "string", "enum": ["deskPanel", "streetPanel", "windowPanel", "crossroadPanel", "collapsePanel", "walkawayPanel"]},
          "duration_frames": {"type": "integer", "minimum": 60},
          "accent_text": {"type": "string"},
          "subtitle_zh": {"type": "string"},
          "subtitle_en": {"type": "string"},
          "scene_image": {"type": "string"},
          "illustration_note": {"type": "string"}
        }
      }
    },
    "audio": {"$ref": "template_data_audio_schema.json#/properties/audio_alignment"}
  }
}
