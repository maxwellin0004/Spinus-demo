      "duration_frames": 126,
      "accent_text": "不是没想过",
      "subtitle_zh": "很多人不是没有天赋，只是从来没替自己活过",
      "subtitle_en": "Many people lack not talent, but the courage to live for themselves.",
      "scene_image": "/images/literary-embers/panel-trapped-desk.png",
      "illustration_note": "书堆、办公桌、沉默人物"
    },
    {
      "scene_id": "le_s04",
      "scene_type": "streetPanel",
      "duration_frames": 150,
      "accent_text": "而是不敢偏离",
      "subtitle_zh": "你抱怨生活沉闷，却把每次选择都交给体面和目光",
      "subtitle_en": "You resent a dull life, yet hand every choice to approval and safety.",
      "scene_image": "/images/literary-embers/panel-gaze-window.png",
      "illustration_note": "路过橱窗的人物和旁观人群"
    },
    {
      "scene_id": "le_s05",
      "scene_type": "windowPanel",
      "duration_frames": 112,
      "accent_text": "沉默地向内坍塌",
      "subtitle_zh": "于是工作是为了交代，努力是为了比较",
      "subtitle_en": "Work becomes explanation, and effort becomes comparison.",
      "scene_image": "/images/literary-embers/panel-comparison-machine.png",
      "illustration_note": "高处窗边、远景城市、坐姿人物"
    },
    {
      "scene_id": "le_s06",
      "scene_type": "crossroadPanel",
      "duration_frames": 156,
      "accent_text": "把决定还给自己",
      "subtitle_zh": "真正困住人的不是起点，而是听见内心后又把它按回去",
      "subtitle_en": "What traps you is not the start, but silencing what you already heard inside.",
      "scene_image": "/images/literary-embers/panel-crossroad-shadow.png",
      "illustration_note": "岔路、巨大阴影、站立人物"
