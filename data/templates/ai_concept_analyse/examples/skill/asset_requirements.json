{
  "project": "ai_concept_analyse / skill example",
  "asset_policy": {
    "strategy": "programmatic first, external images second",
    "notes": [
      "优先使用 React/Remotion 组件生成页面结构和图标。",
      "只有场景页主图建议使用真实图片或截图。",
      "如果真实图片不足，可用程序生成占位面板。"
    ]
  },
  "assets": [
    {
      "asset_id": "bg_grid_dark",
      "type": "generated_background",
      "used_in": ["hook", "document_definition", "compare_basic", "scenario", "flow", "concept_compare", "close"],
      "required": true,
      "source": "React/CSS",
      "visual_role": "全片统一黑底 HUD 包装底层",
      "fallback": "纯黑渐变",
      "editable": ["grid_size", "grid_opacity", "scanline_opacity", "accent_glow_strength"]
    },
    {
      "asset_id": "skill_file_card",
      "type": "generated_icon_card",
      "used_in": ["hook", "document_definition", "close"],
      "required": true,
      "source": "React component",
      "visual_role": "作为主识别物，承担“文档/模块化”认知锚点",
      "fallback": "任意简化文件图标",
      "editable": ["card_color", "fold_corner_size", "label_text"]
    },
    {
      "asset_id": "scenario_video_breakdown",
      "type": "external_image",
      "used_in": ["scenario_1"],
      "required": true,
      "source": "assets/images/scenario_video_breakdown.jpg",
      "visual_role": "展示视频拆解工作台感",
      "fallback": "程序生成分析面板占位图",
      "editable": ["crop", "overlay_opacity", "border_radius"]
    },
    {
      "asset_id": "scenario_ppt",
      "type": "external_image",
      "used_in": ["scenario_2"],
      "required": true,
      "source": "assets/images/scenario_ppt.jpg",
      "visual_role": "展示 PPT 动画页制作场景",
      "fallback": "程序生成页面线框图",
      "editable": ["crop", "overlay_opacity", "border_radius"]
    },
    {
      "asset_id": "scenario_batch_content",
      "type": "external_image",
      "used_in": ["scenario_3"],
      "required": true,
      "source": "assets/images/scenario_batch_content.jpg",
      "visual_role": "展示批量内容生产场景",
      "fallback": "程序生成流程面板",
      "editable": ["crop", "overlay_opacity", "border_radius"]
    },
    {
      "asset_id": "compare_panels",
      "type": "generated_layout",
      "used_in": ["compare_basic", "concept_compare"],
      "required": true,
      "source": "React component",
      "visual_role": "承载前后差异或概念边界",
      "fallback": "纯文字双栏",
      "editable": ["panel_width_ratio", "panel_gap", "accent_border_strength"]
    },
    {
      "asset_id": "flow_cards",
      "type": "generated_layout",
      "used_in": ["flow"],
      "required": true,
      "source": "React component",
      "visual_role": "承载固定工作流链路",
      "fallback": "文字流程列表",
      "editable": ["step_count", "arrow_style", "card_padding"]
    }
  ],
  "fonts": [
    {
      "family": "NotoSansSC",
      "role": "中文主标题与正文"
    },
    {
      "family": "BebasNeue",
      "role": "英文文件名与英文强识别词"
    },
    {
      "family": "SourceSans3",
      "role": "UI 标签、路径条、辅助信息"
    },
    {
      "family": "Orbitron",
      "role": "数字、步骤编号、科技感元素"
    }
  ],
  "review_checklist": [
    "场景图是否与主题一致",
    "图片是否被过度裁切",
    "主识别物是否始终清晰",
    "每个页面的主次层级是否明确",
    "是否出现过多真实图片导致风格跑偏"
  ]
}
