{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ai_concept_analyse template data schema",
  "type": "object",
  "required": [
    "template_id",
    "topic_name",
    "hook_frames",
    "doc_scene",
    "compare_scene",
    "scenarios",
    "flow_scene",
    "concept_compare",
    "close_scene"
  ],
  "properties": {
    "template_id": {
      "type": "string",
      "const": "ai_concept_analyse"
    },
    "topic_name": {
      "type": "string",
      "minLength": 1
    },
    "topic_alias": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "default": "zh-CN"
    },
    "platform": {
      "type": "string"
    },
    "duration_sec": {
      "type": "number",
      "minimum": 30,
      "maximum": 180
    },
    "style_variant": {
      "type": "string",
      "default": "dark_hud_orange"
    },
    "voiceover_units": {
      "$ref": "template_data_audio_schema.json#/properties/voiceover_units"
    },
    "audio_alignment": {
      "$ref": "template_data_audio_schema.json#/properties/audio_alignment"
    },
    "hook_frames": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["label", "title", "ghost", "subtitle"],
        "properties": {
          "label": { "type": "string" },
          "title": { "type": "string" },
          "ghost": { "type": "string" },
          "subtitle": { "type": "string" }
        }
      }
    },
    "doc_scene": {
      "type": "object",
      "required": ["path", "filename", "headline", "cards"],
      "properties": {
        "path": { "type": "string" },
        "filename": { "type": "string" },
        "headline": { "type": "string" },
        "cards": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["title", "description"],
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "compare_scene": {
      "type": "object",
      "required": ["left_title", "right_title", "left_points", "right_points", "footer"],
      "properties": {
        "left_title": { "type": "string" },
        "right_title": { "type": "string" },
        "left_points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "type": "string" }
        },
        "right_points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "type": "string" }
        },
        "footer": { "type": "string" }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["badge", "title", "description", "bullets"],
        "properties": {
          "badge": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "bullets": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "items": { "type": "string" }
          },
          "image_asset": { "type": "string" }
        }
      }
    },
    "flow_scene": {
      "type": "object",
      "required": ["title", "steps"],
      "properties": {
        "title": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 3,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["title", "body"],
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        }
      }
    },
    "concept_compare": {
      "type": "object",
      "required": ["title", "left_label", "right_label", "left_points", "right_points", "footer"],
      "properties": {
        "title": { "type": "string" },
        "left_label": { "type": "string" },
        "right_label": { "type": "string" },
        "left_points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "type": "string" }
        },
        "right_points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "type": "string" }
        },
        "footer": { "type": "string" }
      }
    },
    "close_scene": {
      "type": "object",
      "required": ["headline", "subheadline"],
      "properties": {
        "headline": { "type": "string" },
        "subheadline": { "type": "string" }
      }
    }
  }
}
