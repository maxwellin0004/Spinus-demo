    { "voice_id": "v02", "visual_section_id": "scene_02", "start_frame": 90, "end_frame": 264, "text": "上百家小厂同时收缩\n只剩少数企业守住合规链条", "emphasis_words": ["收缩", "合规链条"], "timing_status": "estimated_after_audio_duration_fit" },
