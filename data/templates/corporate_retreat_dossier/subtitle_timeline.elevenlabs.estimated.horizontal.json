    { "voice_id": "v04", "visual_section_id": "scene_03", "start_frame": 399, "end_frame": 555, "text": "门店还亮着\n但背后的供应链正在换人", "emphasis_words": ["供应链"], "timing_status": "estimated_after_audio_duration_fit" },
    { "voice_id": "v05", "visual_section_id": "scene_04", "start_frame": 564, "end_frame": 747, "text": "真正的分水岭\n不是价格，而是谁能把废料变成稳定产能", "emphasis_words": ["稳定产能"], "timing_status": "estimated_after_audio_duration_fit" },
    { "voice_id": "v06", "visual_section_id": "scene_05", "start_frame": 756, "end_frame": 918, "text": "资金、牌照和客户验证\n开始同时压向同一张表", "emphasis_words": ["同一张表"], "timing_status": "estimated_after_audio_duration_fit" },
    { "voice_id": "v07", "visual_section_id": "scene_06", "start_frame": 930, "end_frame": 1065, "text": "所以新一轮扩产\n不再是抢速度，而是抢确定性", "emphasis_words": ["确定性"], "timing_status": "estimated_after_audio_duration_fit" },
    { "voice_id": "v08a", "visual_section_id": "scene_07", "start_frame": 1074, "end_frame": 1152, "text": "最后留下来的公司\n通常不是声音最大的", "emphasis_words": ["留下来"], "timing_status": "estimated_after_audio_duration_fit" },
