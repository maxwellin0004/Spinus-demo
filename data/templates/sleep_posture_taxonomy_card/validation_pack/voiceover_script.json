  { "time_range": "15.00-20.00", "voice_id": "v04", "section": "type_b", "voiceover_text": "抱臂观察的人，不一定反对，只是还没信任结论。", "target_duration_sec": 4.8, "intended_pause_after_sec": 0.25, "visual_section_id": "scene_04", "tone": "解释", "pace": "中速", "pauses": "逗号处轻停", "emphasis_words": ["抱臂观察", "信任结论"], "timing_status": "estimated", "notes": "正式时间以音频回填" },
  { "time_range": "20.00-25.00", "voice_id": "v05", "section": "type_c", "voiceover_text": "托腮的人看起来安静，其实正在重新组织逻辑。", "target_duration_sec": 4.8, "intended_pause_after_sec": 0.25, "visual_section_id": "scene_05", "tone": "解释", "pace": "中速", "pauses": "逗号处轻停", "emphasis_words": ["托腮", "组织逻辑"], "timing_status": "estimated", "notes": "正式时间以音频回填" },
