[
  { "time_range": "0.00-5.00", "voice_id": "v01", "section": "hook", "voiceover_text": "开会姿势其实会暴露你的工作状态。", "target_duration_sec": 4.2, "intended_pause_after_sec": 0.3, "visual_section_id": "scene_01", "tone": "轻科普", "pace": "中速", "pauses": "句末短停", "emphasis_words": ["开会姿势", "工作状态"], "timing_status": "estimated", "notes": "正式时间以音频回填" },
