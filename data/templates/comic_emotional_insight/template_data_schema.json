{
  "template_id": "comic_emotional_insight",
  "type": "object",
  "required": [
    "topic_name",
    "duration_sec",
    "orientation",
    "style_variant",
    "hook",
    "story_a",
    "mechanism",
    "story_b",
    "story_c",
    "triptych",
    "close"
  ],
  "properties": {
    "topic_name": {
      "type": "string"
    },
    "duration_sec": {
      "type": "number",
      "default": 60
    },
    "orientation": {
      "type": "string",
      "enum": [
        "horizontal"
      ]
    },
    "style_variant": {
      "type": "string"
    },
    "voiceover_units": {
      "$ref": "template_data_audio_schema.json#/properties/voiceover_units"
    },
    "audio_alignment": {
      "$ref": "template_data_audio_schema.json#/properties/audio_alignment"
    },
    "hook": {
      "type": "object",
      "required": [
        "left_label",
        "right_label",
        "title",
        "subtitle",
        "caption",
        "left_image_src",
        "right_image_src"
      ]
    },
    "story_a": {
      "type": "object",
      "required": [
        "kicker",
        "title",
        "bubble_lines",
        "caption",
        "image_src"
      ]
    },
    "mechanism": {
      "type": "object",
      "required": [
        "tag",
        "title",
        "steps",
        "caption",
        "image_src"
      ]
    },
    "story_b": {
      "type": "object",
      "required": [
        "kicker",
        "title",
        "bubble_lines",
        "caption",
        "image_src"
      ]
    },
    "story_c": {
      "type": "object",
      "required": [
        "kicker",
        "title",
        "bubble_lines",
        "caption",
        "image_src"
      ]
    },
    "triptych": {
      "type": "object",
      "required": [
        "title",
        "cards",
        "caption"
      ]
    },
    "close": {
      "type": "object",
      "required": [
        "title",
        "body",
        "caption",
        "image_src"
      ]
    }
  }
}
