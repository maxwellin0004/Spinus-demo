{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "new_signals audio alignment schema",
  "type": "object",
  "required": ["voiceover_units", "audio_alignment"],
  "properties": {
    "voiceover_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "voice_id",
          "section",
          "text",
          "target_duration_sec",
          "intended_pause_after_sec",
          "emphasis_words",
          "visual_section_id",
          "timing_status"
        ],
        "properties": {
          "voice_id": { "type": "string", "pattern": "^v[0-9]{2,}$" },
          "section": { "type": "string" },
          "text": { "type": "string", "minLength": 1 },
          "target_duration_sec": { "type": "number", "minimum": 0.5 },
          "intended_pause_after_sec": { "type": "number", "minimum": 0 },
          "emphasis_words": { "type": "array", "items": { "type": "string" } },
          "visual_section_id": { "type": "string" },
          "timing_status": {
            "type": "string",
            "enum": ["estimated", "aligned", "estimated_after_audio_duration_fit"]
          }
        }
      }
    },
    "audio_alignment": {
      "type": "object",
      "required": ["tts_provider", "voiceover_audio_path", "subtitle_timeline_path", "alignment_status"],
      "properties": {
        "tts_provider": { "type": "string", "default": "elevenlabs" },
        "voiceover_audio_path": { "type": "string" },
        "subtitle_timeline_path": { "type": "string" },
        "alignment_status": {
          "type": "string",
          "enum": ["not_generated", "estimated", "aligned", "estimated_after_audio_duration_fit"]
        },
        "alignment_method": {
          "type": "string",
          "enum": ["forced_alignment", "transcription_timestamps", "duration_fit", "manual_review"]
        }
      }
    }
  }
}
