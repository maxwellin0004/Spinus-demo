    "card.left": "Overlay card left offset",
    "card.avatarText": "Avatar circle text",
    "post.author": "Card header author",
    "post.badge": "Badge label",
    "post.metaLine": "Meta line prefix",
    "post.paragraphs": "Body paragraphs",
    "motion.backgroundScaleFrom": "Background scale start",
    "motion.backgroundScaleTo": "Background scale end",
    "motion.backgroundShiftY": "Background Y drift",
    "motion.cardTranslateYIn": "Card rise-in offset",
