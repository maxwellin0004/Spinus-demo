{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CombinatorialParadoxCinematicAudio",
  "type": "object",
  "required": ["voiceover_units", "audio_alignment"],
  "properties": {
    "voiceover_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "voice_id",
          "section",
          "text",
          "target_duration_sec",
          "intended_pause_after_sec",
          "emphasis_words",
          "visual_section_id",
          "timing_status"
        ],
        "properties": {
          "voice_id": { "type": "string" },
          "section": { "type": "string" },
          "text": { "type": "string" },
          "target_duration_sec": { "type": "number" },
          "intended_pause_after_sec": { "type": "number" },
          "emphasis_words": {
            "type": "array",
            "items": { "type": "string" }
          },
          "visual_section_id": { "type": "string" },
          "timing_status": { "type": "string" }
        }
      }
    },
    "audio_alignment": {
      "type": "object",
      "required": [
        "tts_provider",
        "voiceover_audio_path",
        "subtitle_timeline_path",
        "alignment_status"
      ],
      "properties": {
        "tts_provider": { "type": "string" },
        "voiceover_audio_path": { "type": "string" },
        "subtitle_timeline_path": { "type": "string" },
        "alignment_status": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
