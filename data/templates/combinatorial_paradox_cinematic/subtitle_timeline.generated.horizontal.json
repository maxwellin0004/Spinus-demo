  "cues": [
    {
      "voice_id": "v01",
      "visual_section_id": "scene_01",
      "start_sec": 0.0,
      "end_sec": 4.96,
      "startFrame": 0,
      "endFrame": 149,
      "text": "只要二十三个人，同一天生日撞上的概率，就已经超过一半。",
      "emphasisWords": [
        "二十三个人",
        "超过一半"
      ]
    },
    {
      "voice_id": "v02",
      "visual_section_id": "scene_01",
      "start_sec": 5.04,
      "end_sec": 9.92,
      "startFrame": 151,
      "endFrame": 298,
      "text": "这不是直觉错一点，而是你的计数方式从一开始就错了。",
      "emphasisWords": [
        "计数方式"
      ]
    },
    {
      "voice_id": "v03",
      "visual_section_id": "scene_02",
      "start_sec": 10.0,
      "end_sec": 17.04,
      "startFrame": 300,
      "endFrame": 511,
      "text": "大多数人会盯着三百六十五天，却忽略了二十三个人之间会产生二百五十三组配对。",
      "emphasisWords": [
        "三百六十五天",
        "二百五十三组配对"
      ]
    },
    {
      "voice_id": "v04",
      "visual_section_id": "scene_03",
      "start_sec": 17.16,
      "end_sec": 23.279,
      "startFrame": 515,
      "endFrame": 698,
      "text": "每多一个人，不是多一个可能，而是同时和前面所有人都新增一次比较。",
      "emphasisWords": [
        "所有人",
        "新增一次比较"
      ]
    },
    {
      "voice_id": "v05",
      "visual_section_id": "scene_04",
      "start_sec": 23.359,
      "end_sec": 28.719,
      "startFrame": 701,
      "endFrame": 862,
      "text": "所以概率上升得不是线性，而是组合数在把空间快速压扁。",
      "emphasisWords": [
        "不是线性",
        "组合数"
      ]
    },
    {
      "voice_id": "v06",
      "visual_section_id": "scene_04",
      "start_sec": 28.839,
      "end_sec": 34.959,
      "startFrame": 865,
      "endFrame": 1049,
      "text": "当人数来到二十三，至少一对同生日的概率大约是百分之五十点七。",
      "emphasisWords": [
        "二十三",
        "百分之五十点七"
      ]
    },
    {
      "voice_id": "v07",
      "visual_section_id": "scene_05",
      "start_sec": 35.119,
      "end_sec": 40.719,
      "startFrame": 1054,
      "endFrame": 1222,
      "text": "这类悖论真正提醒你的，是别再用单点直觉去看成组关系。",
      "emphasisWords": [
        "单点直觉",
        "成组关系"
      ]
    },
    {
      "voice_id": "v08",
      "visual_section_id": "scene_06",
      "start_sec": 40.879,
      "end_sec": 45.119,
      "startFrame": 1226,
      "endFrame": 1354,
      "text": "很多看上去不可能的事，换一个计数框架，立刻就变得合理。",
      "emphasisWords": [
        "计数框架"
      ]
    }
  ]
}