      "visual_section_id": "debate_stage",
      "timing_status": "estimated_after_audio_duration_fit"
    },
    {
      "voice_id": "v07",
      "section": "debate",
      "text": "Left says enjoy now. Right says invest now. You are pulled both ways.",
