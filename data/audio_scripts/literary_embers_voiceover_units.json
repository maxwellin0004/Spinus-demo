  "voiceover_units": [
    {
      "voice_id": "le_v01",
      "section": "hook",
      "text": "\u8fd9\u53e5\u8bdd\u4f1a\u523a\u75db\u6240\u6709\u4e0d\u7518\u5fc3\u5374\u4e00\u76f4\u66ff\u522b\u4eba\u6d3b\u7684\u4eba\u3002",
      "subtitle_zh": "\u8fd9\u53e5\u8bdd\u4f1a\u523a\u75db\u6240\u6709\n\u4e0d\u7518\u5fc3\u5374\u4e00\u76f4\u66ff\u522b\u4eba\u6d3b\u7684\u4eba",
      "subtitle_en": "This line hits everyone\nwho keeps living for other eyes.",
      "target_duration_sec": 4.6,
      "intended_pause_after_sec": 0.2,
      "emphasis_words": ["\u66ff\u522b\u4eba\u6d3b"],
      "visual_section_id": "le_s01",
